# Port configuration (optional, defaults to 3000)
PORT=3000

# NVIDIA NIM API Key (required)
# Get yours for free at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-YOUR_NVIDIA_API_KEY_HERE

# Allowed CORS Origins (optional, comma-separated, defaults to '*' in dev)
# In production, set this to your Chrome Extension origin (e.g. chrome-extension://your-extension-id)
# ALLOWED_ORIGINS=chrome-extension://your-extension-id
